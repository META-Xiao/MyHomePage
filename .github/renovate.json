{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":pinVersions",
    ":automergeMinor"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "description": "Auto-merge patch updates for non-major deps",
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "description": "Dockerfile base images — pin to LTS tags",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["node"],
      "allowedVersions": "/^22/"
    },
    {
      "description": "Group pnpm updates together",
      "matchManagers": ["dockerfile", "npm"],
      "matchPackageNames": ["pnpm"],
      "groupName": "pnpm"
    }
  ],
  "schedule": ["before 9am on Monday"],
  "timezone": "Asia/Shanghai"
}
